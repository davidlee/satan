#!/usr/bin/env sh
# SATAN intervention projection rebuild.  Invokes
# `satan-rebuild-interventions' over emacsclient; the elisp side
# replays every intervention audit-event under `satan-runs-dir'
# into the satan_interventions / satan_intervention_outcomes
# projection (migration 0006_interventions.sql).  Idempotent.
set -eu
exec emacsclient --eval "(satan-rebuild-interventions)"
